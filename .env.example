# Backend
#ASPNETCORE_ENVIRONMENT=Development
#API_URLS=http://localhost:5000
#App__FrontendUrl=http://localhost:5173

# Frontend
#VITE_API_BASE_URL=http://localhost:5000

# SQL Server local
# Opcion con autenticacion de Windows:
#ConnectionStrings__DefaultConnection=Server=localhost;Database=EmployabilityPlatform;Trusted_Connection=True;TrustServerCertificate=True;

# Opcion con usuario y contrasena:
# ConnectionStrings__DefaultConnection=Server=localhost;Database=EmployabilityPlatform;User Id=sa;Password=TU_PASSWORD;TrustServerCertificate=True;

# Correo SMTP
# Para Gmail, crea una "App password"; no uses tu password personal.

#Email__Provider=Smtp
#Email__SenderName=Plataforma de Empleabilidad
#Email__SenderAddress=no-reply@example.com
#Email__SmtpHost=smtp.gmail.com
#Email__SmtpPort=587
#Email__SmtpUsername=tu-correo@gmail.com
#Email__SmtpPassword=TU_APP_PASSWORD
#Email__EnableSsl=true

# Tambien se soporta este formato:
# Smtp__Host=smtp.gmail.com
# Smtp__Port=587
# Smtp__Username=tu-correo@gmail.com
# Smtp__Password=TU_APP_PASSWORD
# Smtp__FromName=Plataforma de Empleabilidad
# Smtp__FromAddress=tu-correo@gmail.com
# Smtp__EnableSsl=true

# La aplicacion no guarda correos localmente. SMTP es obligatorio.
